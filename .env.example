# Path to your music directory on the host machine.
# This folder is mounted read-only into the backend container.
MUSIC_DIR=~/Music

# Backend URL as seen from the browser (used at frontend build time).
# Change the host/port if you expose the backend on a non-default address.
VITE_BACKEND_URL=http://localhost:8080

# Set to true to start audio playback automatically when the page loads.
VITE_AUTO_START_AUDIO=false
